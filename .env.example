# ── Banco de dados ────────────────────────────────────────────────────────────
DB_USER=libraflow
DB_PASSWORD=libraflow_secret_change_me
DB_HOST=postgres
DB_PORT=5432

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=libraflow
MONGO_PASSWORD=mongo_secret_change_me

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBIT_USER=libraflow
RABBIT_PASSWORD=rabbit_secret_change_me

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=jwt_super_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# ── SMTP (notificações) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development
