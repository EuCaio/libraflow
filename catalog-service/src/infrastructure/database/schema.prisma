generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id               String   @id @default(uuid())
  title            String
  isbn             String   @unique
  authors          Json
  categoryId       String
  totalCopies      Int
  availableCopies  Int
  publishedYear    Int?
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([categoryId])
  @@map("books")
}
